# Ejemplo de variables de entorno para proyecto ServiMeet
# Copia este archivo en un ".env" y rellena los valores reales.

PORT=3000
DATABASE_URL="mysql://servimeet_user:TU_CONTRASEÑA@localhost:3306/servimeet_dev"
JWT_SECRET="FRASE_SECRETA_AQUI"

# OPCIONAL: credenciales desglosadas (Prisma usa DATABASE_URL). Útiles para scripts o para construirla desde código.
DATABASE_HOST="localhost"
DATABASE_PORT=3306
DATABASE_USER="servimeet_user"
DATABASE_PASSWORD="TU_PASSWORD"
DATABASE_NAME="servimeet_dev"