generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  CLIENT
  PRO
  ADMIN
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  DONE
  CANCELLED
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CLIENT)
  city      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  services         Service[] @relation("ProServices")
  requestsAsClient Request[] @relation("ClientRequests")
  requestsAsPro    Request[] @relation("ProRequests")
  reviewsGiven     Review[]  @relation("ReviewsGiven")
  reviewsReceived  Review[]  @relation("ReviewsReceived")
}

model Service {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  category    String
  price       Float
  zone        String
  imageUrl    String?
  imageId     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  proId Int
  pro   User @relation("ProServices", fields: [proId], references: [id], onDelete: Cascade)

  requests Request[]
  reviews  Review[]

  @@index([proId])
  @@index([category])
  @@index([isActive])
}

model Request {
  id         Int           @id @default(autoincrement())
  message    String
  dateNeeded DateTime?
  budget     Float?
  status     RequestStatus @default(PENDING)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  clientId Int
  client   User @relation("ClientRequests", fields: [clientId], references: [id], onDelete: Cascade)

  proId Int
  pro   User @relation("ProRequests", fields: [proId], references: [id], onDelete: Cascade)

  review Review?

  @@index([serviceId])
  @@index([clientId])
  @@index([proId])
  @@index([status])
}

model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requestId Int     @unique
  request   Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  serviceId Int
  service   Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  clientId Int
  client   User @relation("ReviewsGiven", fields: [clientId], references: [id], onDelete: Cascade)

  proId Int
  pro   User @relation("ReviewsReceived", fields: [proId], references: [id], onDelete: Cascade)

  @@index([serviceId])
  @@index([clientId])
  @@index([proId])
}
